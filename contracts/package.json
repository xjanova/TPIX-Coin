{
  "name": "tpix-contracts",
  "version": "1.0.0",
  "description": "TPIX Chain Smart Contracts",
  "private": true,
  "scripts": {
    "compile": "npx hardhat compile",
    "deploy:identity": "npx hardhat run scripts/deploy-identity.js --network tpix",
    "deploy:identity:local": "npx hardhat run scripts/deploy-identity.js --network localhost",
    "verify": "npx hardhat run scripts/verify-identity.js --network tpix",
    "verify:sources": "node scripts/verify-sources.js",
    "verify:recheck": "node scripts/verify-sources.js --recheck"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-ethers": "^3.0.0",
    "ethers": "^6.13.0",
    "hardhat": "^2.22.0"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.6.1"
  }
}
